{
  "manifest_version": 3,
  "name": "Force Times New Roman TED",
  "version": "1.10001",
  "description": "Forces my websites to use Times New Roman bc i felt like it TED",
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/*",
        "*://*.open.spotify.com/*",
        "*://*.fishingfrenzy.blooket.com/play/fishing/*",
        "*://*.bellarinesc-vic.compass.education/*",
        "*://*.play.blooket.com/play/*"
      ],
      "css": ["style.css"]
    }
  ]
}